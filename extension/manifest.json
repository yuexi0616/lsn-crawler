{
  "manifest_version": 3,
  "name": "LMS 实验报告爬取",
  "version": "1.1",
  "description": "将 LMS 实验操作手册一键保存为 Markdown",
  "permissions": ["activeTab", "downloads", "scripting"],
  "host_permissions": ["http://10.30.0.135/*", "https://10.30.0.135/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LMS 实验报告爬取"
  },
  "content_scripts": [
    {
      "matches": ["http://10.30.0.135/*", "https://10.30.0.135/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}